llm:
  providers:
    openai_main:
      api_base: https://api.openai.com/v1
      api_key: ${ENV:OPENAI_API_KEY}
    kimi_main:
      api_base: https://api.moonshot.cn/v1
      api_key: ${ENV:KIMI_API_KEY}
    minimax_main:
      api_base: https://api.minimaxi.com/v1
      api_key: ${ENV:MINIMAX_API_KEY}
  models:
    gpt_deep:
      provider: openai_main
      model: gpt-5.4
    kimi_fast:
      provider: kimi_main
      model: moonshot-v1-8k
    minimax_hunter:
      provider: minimax_main
      model: minimax/MiniMax-M2.5-highspeed
  bindings:
    defaults.fast: kimi_fast
    defaults.deep: gpt_deep
    commander.brain: gpt_deep
    controller.main: kimi_fast
    meeting.selection.fast: kimi_fast
    meeting.selection.deep: gpt_deep
    meeting.review.fast: kimi_fast
    meeting.review.deep: gpt_deep
    optimizer.loss_analysis: gpt_deep
    agent.TrendHunter: minimax_hunter
    agent.Contrarian: minimax_hunter
data:
  runtime_policy:
    allow_online_fallback: false
    allow_capital_flow_sync: false
