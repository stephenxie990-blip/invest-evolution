# provider keys are consumed by config/control_plane.local.yaml
OPENAI_API_KEY=<your-openai-key>
MINIMAX_API_KEY=<your-minimax-key>
WEB_API_TOKEN=<strong-random-token>
WEB_API_REQUIRE_AUTH=true
WEB_API_PUBLIC_READ_ENABLED=false
WEB_RATE_LIMIT_ENABLED=true
WEB_RATE_LIMIT_WINDOW_SEC=60
WEB_RATE_LIMIT_READ_MAX=120
WEB_RATE_LIMIT_WRITE_MAX=20
WEB_RATE_LIMIT_HEAVY_MAX=5
GUNICORN_BIND=127.0.0.1:8080
# 生产默认：Web/API 无状态化；embedded runtime 仅保留给 compat/dev 调试。
WEB_EMBEDDED_RUNTIME_ENABLED=false
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
