{
  "id": "mean_reversion",
  "name": "Mean Reversion Gene",
  "enabled": true,
  "priority": 60,
  "description": "Catch oversold rebounds with strict risk limits.",
  "rules": {
    "entry": {
      "rsi_max": 30,
      "drop_20d_min": 0.12,
      "volume_ratio_min": 1.2
